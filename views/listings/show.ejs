<% layout('layouts/boilerplate') -%>
    <div class="row mt-3">
        <div class="col-9 offset-2">
    <div class="card col-7 offset-2 listing_card">
        <h3><%= listingdata.title%></h3>
        <img class="card-img-top show-img" src="<%= listingdata.image.url%>" alt="listing image">
        <div class="card-body">
        <%= listingdata.title%> <br>
        <%= listingdata.description%> <br>
        &#8377;<%= listingdata.price.toLocaleString("en-IN")%> <br>
        <%= listingdata.location%> <br>
        <%= listingdata.country%> <br>
  </div>
</div>
    <div class="btns">
        <a href="/listings/<%=listingdata._id%>/edit" class="btn btn-dark col-1 offset-2 add-btn">Edit</a>
        <form method="post" action="/listings/<%=listingdata._id %>?_method=DELETE">
        <button  class="btn btn-dark offset-5">Delete</button>
    </form>
    </div>
    <div class="col-8 offset-2 mb-3">
        <hr>
        <h4>Review</h4>
        <form action="/listings/<%=listingdata.id %>/reviews" method="post" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
                <label for="rating" class="form-lable">Rating</label>
                <input type="range" class="form-range" min="1" max="6" id="rating" name="review[rating]">
            </div>
            <div class="mb-3">
                <label for="comment" class="form-lable">Comment</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
                <div class="invalid-feedback">Please add some comments for review</div>
            </div>
            <button class="btn btn-outline-dark mb-3">Submit</button>
        </form>
        <p><b>All Reviews</b></p>
        <div class="row">
            <% for(review of listingdata.reviews){ %>
            <div class="card col-5 ms-1 mb-3">
                <div class="card-body">
                    <h5 class="card-title">Anurag</h5>
                    <p class="card-text"><%=review.comment %></p>
                    <p class="card-text"><%=review.rating %> Stars</p>
                </div>
                <form class="mb-3" method="post" action="/listings/<%=listingdata._id %>/reviews/<%= review.id%>?_method=DELETE">
                    <button class="btn btn-sm btn-dark">Delete</button>
                </form>

            </div>
            <% } %>
        </div>
    </div>
</div>